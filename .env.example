# Root .env.example — copy to .env and adjust as needed
# docker-compose reads this automatically if a .env file exists at the root

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_INITDB_DATABASE=leetcode-analyzer

# ── Backend ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
MONGODB_URI=mongodb://mongodb:27017/leetcode-analyzer
REDIS_URL=redis://redis:6379
CACHE_TTL_SECONDS=3600
FRONTEND_URL=http://localhost:80
ML_SERVICE_URL=http://ml-service:8000
ML_TIMEOUT_MS=5000

# ── ML Service ────────────────────────────────────────────────────────────────
ML_PORT=8000
ALLOWED_ORIGINS=http://backend:5000,http://localhost:80
